{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "node -e \"require('fs').existsSync('dist/assets')||require('child_process').execSync('npm run build',{stdio:'inherit'})\" && node server.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
